# Validation Messages
msgid "All 5 energy property categories are required"
msgstr "ต้องระบุคุณสมบัติพลังงานครบทั้ง 5 หมวดหมู่"

msgid "All 5 energy property categories must be present"
msgstr "ต้องมีคุณสมบัติพลังงานครบทั้ง 5 หมวดหมู่"

msgid "All energy property ratings must be between 0 and 8"
msgstr "คะแนนพลังงานทั้งหมดต้องอยู่ระหว่าง 0 ถึง 8"

msgid "At least 1 gallery image is required"
msgstr "ต้องมีรูปภาพในแกลเลอรีอย่างน้อย 1 รูป"

msgid "Maximum 10 gallery images allowed"
msgstr "สามารถอัปโหลดรูปภาพได้สูงสุด 10 รูป"

msgid "At least 1 stone must be added"
msgstr "ต้องเพิ่มหินอย่างน้อย 1 ชนิด"

msgid "Maximum 15 stones allowed"
msgstr "สามารถเพิ่มหินได้สูงสุด 15 ชนิด"

msgid "All stones must have a name"
msgstr "หินทุกชนิดต้องมีชื่อ"

msgid "Thai energy description must be at least 100 characters"
msgstr "คำอธิบายพลังงานภาษาไทยต้องมีอย่างน้อย 100 ตัวอักษร"

msgid "Only JPG, PNG, and WebP images are allowed"
msgstr "รองรับเฉพาะไฟล์ภาพ JPG, PNG และ WebP เท่านั้น"

msgid "Image size must be less than 5MB"
msgstr "ขนาดไฟล์ภาพต้องน้อยกว่า 5MB"

msgid "Image must be at least 800×800 pixels"
msgstr "ขนาดภาพต้องมีอย่างน้อย 800×800 พิกเซล"

msgid "Image must not exceed 4000×4000 pixels"
msgstr "ขนาดภาพต้องไม่เกิน 4000×4000 พิกเซล"

